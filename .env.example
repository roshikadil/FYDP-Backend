# --- DATABASE ---
MONGODB_URI=mongodb+srv://...

# --- SERVER ---
PORT=5000
NODE_ENV=production
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# --- AI MODEL ---
# The URL of your separate AI service on Railway
# Example: https://ai-model-production.up.railway.app/detect
AI_MODEL_URL=http://localhost:5005/detect

# --- CLIENT URLS ---
WEB_APP_URL=https://your-dashboard.vercel.app
MOBILE_APP_URL=http://localhost:3001

# --- EMAIL ---
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
